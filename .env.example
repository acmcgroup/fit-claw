# Public site URL (Stripe success/cancel redirects). In Vercel, set to https://your-domain.com
# If omitted on Vercel, VERCEL_URL is used for redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Postgres (Neon, Supabase, Vercel Postgres integration, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Stripe — server only (never NEXT_PUBLIC_)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: price id for Checkout
STRIPE_PRICE_ID=price_...

# Install script delivery — generate per-order tokens in your webhook handler
INSTALL_TOKEN_SIGNING_SECRET=change-me-to-a-long-random-string
